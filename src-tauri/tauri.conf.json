{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freematics Config Manager",
  "version": "1.0.0-beta",
  "identifier": "com.maxynetwork.freematics-config-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Freematics Config Manager",
        "width": 1100,
        "height": 750,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "appimage"],
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "../firmware/dist/manifest.json",
      "../firmware/dist/telelogger-patched.bin"
    ]
  }
}
